<ul class="wp-block-latest-posts__list has-dates wp-block-latest-posts">
{%- for post in collections.news | limit(2) %}
	<li>
		<a class="wp-block-latest-posts__post-title" href="{{ post.url }}">{{ post.data.title }}</a>
		<time datetime="{{ post.date | isoDate }}" class="wp-block-latest-posts__post-date">{{ post.date | readableDate }}</time>
	</li>
{%- endfor %}
</ul>
